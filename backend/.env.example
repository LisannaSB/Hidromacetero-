# Modo del sensor: "mock" (por defecto, sin hardware) o "real" (Dracal fisico)
SENSOR_MODE=mock

# Solo aplica si SENSOR_MODE=real
DRACAL_SERIAL=E25876

# Ruta al ejecutable dracal-usb-get. Si esta en el PATH del sistema basta
# con "dracal-usb-get" (o "dracal-usb-get.exe" en Windows). Si no, usa la
# ruta completa, por ejemplo en Windows:
# DRACAL_BINARY=C:\Program Files (x86)\DracalView\dracal-usb-get.exe
DRACAL_BINARY=dracal-usb-get
